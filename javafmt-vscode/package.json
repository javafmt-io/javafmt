{
  "name": "javafmt",
  "displayName": "javafmt",
  "description": "Opinionated Java formatter — fast, deterministic, 150-char line width",
  "version": "0.1.0",
  "publisher": "javafmt",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/javafmt-io/javafmt"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Formatters"],
  "activationEvents": ["onLanguage:java"],
  "main": "./out/extension",
  "contributes": {
    "commands": [
      {
        "command": "javafmt.restartDaemon",
        "title": "javafmt: Restart Daemon"
      }
    ],
    "configuration": {
      "title": "javafmt",
      "properties": {
        "javafmt.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable javafmt as the formatter for Java files."
        },
        "javafmt.javaExecutable": {
          "type": "string",
          "default": "java",
          "description": "Path to the Java executable used to launch the daemon."
        },
        "javafmt.daemonJar": {
          "type": "string",
          "default": "",
          "description": "Override path to javafmt-daemon.jar. Defaults to the bundled jar."
        },
        "javafmt.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Format Java files on save. Shorthand for setting editor.formatOnSave and [java].editor.defaultFormatter yourself."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc --watch -p ./",
    "package": "vsce package --out build/javafmt-vscode.vsix",
    "test": "jest --json --outputFile=build/test-results.json",
    "test:integration": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.19.40",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.9.1",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.3.0"
  }
}
